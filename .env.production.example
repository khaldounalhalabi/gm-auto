# ---------------------------------------------------------------------------
# Production environment template for the Docker Compose / Dokploy deployment.
# Copy this file to .env, replace the placeholder values, and keep it secret.
# ---------------------------------------------------------------------------

APP_NAME="GM Auto"
APP_ENV=production
APP_KEY=
# Generate with: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://gm-auto.example.com
APP_DOMAIN=gm-auto.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ---------------------------------------------------------------------------
# Database (MariaDB service named "db" in docker-compose.yml)
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=gm_auto
DB_USERNAME=gm_auto
DB_PASSWORD=change_me_to_a_strong_password

# These variables configure the MariaDB container itself.
MYSQL_DATABASE=gm_auto
MYSQL_USER=gm_auto
MYSQL_PASSWORD=change_me_to_a_strong_password
MYSQL_ROOT_PASSWORD=change_me_to_a_strong_root_password

# ---------------------------------------------------------------------------
# Sessions / Cache / Queues (using the Redis service named "redis")
# ---------------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=gm_auto

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Mail (configure for your provider; defaults to log driver)
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Storage / Third-party
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Deployment helpers
# ---------------------------------------------------------------------------
# Set RUN_MIGRATIONS=true on the first deploy to create the database tables.
# Leave it false afterward and run migrations manually through Dokploy/CLI.
RUN_MIGRATIONS=false
TRUSTED_PROXIES=*
